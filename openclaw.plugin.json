{
  "id": "solana-trader",
  "name": "Solana Trader",
  "description": "Public edition V1-Upgraded — Solana trading agent with X/Twitter social intel (read-only, no posting), standardized tool envelopes, intelligence lab, prompt injection scrubbing, and split skill architecture. Full V1 trading capabilities plus 17 new intelligence tools.",
  "enabledByDefault": true,
  "activation": {
    "onStartup": true
  },
  "skills": ["skills/solana-trader"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "orchestratorUrl": {
        "type": "string",
        "description": "Base URL of the trading orchestrator API"
      },
      "walletId": {
        "type": "string",
        "description": "Wallet ID (UUID string) for this agent's trading account"
      },
      "apiKey": {
        "type": "string",
        "description": "API key obtained from signup or https://traderclaw.ai/register"
      },
      "externalUserId": {
        "type": "string",
        "description": "External user ID for signup (auto-generated if not provided)"
      },
      "refreshToken": {
        "type": "string",
        "description": "Refresh token from last session (auto-populated after authentication)"
      },
      "recoverySecret": {
        "type": "string",
        "description": "Consumable recovery secret used to restore a session after refresh-token failure"
      },
      "walletPublicKey": {
        "type": "string",
        "description": "Solana wallet public key (auto-populated after session establishment)"
      },
      "walletPrivateKey": {
        "type": "string",
        "deprecated": true,
        "description": "Optional base58 signing key when the server requires wallet proof. Prefer TRADERCLAW_WALLET_PRIVATE_KEY in OpenClaw/gateway merged env or systemd EnvironmentFile instead of plaintext JSON (never commit)."
      },
      "apiTimeout": {
        "type": "integer",
        "minimum": 1000,
        "maximum": 300000,
        "default": 120000,
        "description": "HTTP request timeout in milliseconds (on-chain trades can take time)"
      },
      "agentId": {
        "type": "string",
        "description": "Agent ID for event-to-agent forwarding (e.g., 'main'). When set, subscriptions automatically include this agentId so the orchestrator forwards stream events to your Gateway via /v1/responses."
      },
      "gatewayBaseUrl": {
        "type": "string",
        "description": "Public HTTPS URL of your OpenClaw Gateway used by orchestrator event forwarding."
      },
      "gatewayToken": {
        "type": "string",
        "description": "Bearer token used by orchestrator when calling your Gateway /v1/responses."
      },
      "forwardTelegramRecipient": {
        "type": "string",
        "description": "Telegram @username or numeric chat id for orchestrator reply forwarding (optional). Legacy key forwardTelegramChatId is also accepted."
      },
      "telegramBotToken": {
        "type": "string",
        "description": "Telegram bot token from @BotFather. Required only to resolve @username to chat id via Bot API. Set in plugin config (not environment variables) for OpenClaw compatibility."
      },
      "workspaceDir": {
        "type": "string",
        "description": "Override workspace directory path. Defaults to ~/.openclaw/workspace/ when unset."
      },
      "dataDir": {
        "type": "string",
        "description": "Absolute path for session sidecar (session-tokens.json), state, and logs. Defaults to ~/.traderclaw-v1-data when unset. Set explicitly on VPS so CLI and gateway agree."
      },
      "bootstrapDecisionCount": {
        "type": "integer",
        "minimum": 1,
        "maximum": 50,
        "default": 10,
        "description": "Number of recent decisions to include in bootstrap digest"
      },
      "bootstrapBulletinWindowHours": {
        "type": "integer",
        "minimum": 1,
        "maximum": 168,
        "default": 24,
        "description": "Hours of bulletin entries to include in bootstrap digest"
      },
      "dailyLogRetentionDays": {
        "type": "integer",
        "minimum": 1,
        "maximum": 365,
        "default": 30,
        "description": "Number of days to retain daily log files before pruning"
      },
      "kaybaApiKey": {
        "type": "string",
        "description": "Kayba tracing API key. When set, every tool call is traced and sent to the Kayba dashboard."
      },
      "kaybaFolder": {
        "type": "string",
        "default": "traderclaw",
        "description": "Folder name for organizing traces in the Kayba dashboard."
      },
      "beta": {
        "type": "object",
        "description": "Beta feature flags. Enable experimental capabilities that are not yet enabled by default.",
        "properties": {
          "xPosting": {
            "type": "boolean",
            "default": false,
            "description": "Enable X/Twitter write tools: x_post_tweet and x_reply_tweet. Requires your X App permissions set to Read+Write and tokens regenerated. When false (default), only the 3 read tools are registered (x_read_mentions, x_search_tweets, x_get_thread)."
          }
        },
        "additionalProperties": false
      },
      "x": {
        "type": "object",
        "description": "X/Twitter configuration for read-only social intel tools",
        "properties": {
          "consumerKey": { "type": "string", "description": "X App consumer key (shared across all agents)" },
          "consumerSecret": { "type": "string", "description": "X App consumer secret" },
          "profiles": {
            "type": "object",
            "description": "Per-agent X profiles. Keys are agent IDs.",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "accessToken": { "type": "string" },
                "accessTokenSecret": { "type": "string" },
                "userId": { "type": "string" },
                "username": { "type": "string" }
              },
              "required": ["accessToken", "accessTokenSecret"]
            }
          }
        }
      }
    }
  },

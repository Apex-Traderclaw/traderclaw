// OpenClaw Gateway Configuration — TraderClaw V1 (Single Agent)
// Single "main" agent with 5-minute heartbeat + cron jobs for autonomous operation.
// Without this config, the agent ONLY runs when a user sends a message.
// With this config, the agent wakes every 5 minutes AND runs scheduled maintenance jobs.
// See: docs/scheduling-architecture.md
{
  agents: {
    list: [
      {
        id: "main",
        default: true,
        heartbeat: { every: "5m", target: "last" }
        // Core trading loop — scan, analyze, decide, execute, monitor.
        // Wakes every 5 minutes to check alpha buffer, positions, and market conditions.
        // Also receives all cron jobs since V1 is a single-agent system.
      }
    ]
  },

  cron: {
    enabled: true,
    maxConcurrentRuns: 2,
    sessionRetention: "24h",
    runLog: {
      maxBytes: "2mb",
      keepLines: 2000
    },
    jobs: [
      // ── Strategy & Learning ───────────────────────────────────────
      {
        id: "strategy-evolution",
        schedule: "0 */4 * * *",          // Every 4 hours
        agentId: "strategy-researcher",
        message: "CRON_JOB: strategy_evolution — Review trade journal, compute weight adjustments, update strategy. Only update if sufficient closed trades have accumulated.",
        enabled: true
      },
      {
        id: "source-reputation",
        schedule: "0 */3 * * *",          // Every 3 hours
        agentId: "alpha-signal-analyst",
        message: "CRON_JOB: source_reputation_recalc — Analyze which alpha signal sources led to wins vs losses. Update reputation tracking in memory.",
        enabled: true
      },

      // ── Risk & Audit ──────────────────────────────────────────────
      {
        id: "risk-audit",
        schedule: "0 */2 * * *",          // Every 2 hours
        agentId: "risk-officer",
        message: "CRON_JOB: portfolio_risk_audit — Portfolio stress tests, exposure checks, correlation analysis, drawdown monitoring. Produce risk report for CTO.",
        enabled: true
      },

      // ── On-Chain Intelligence ─────────────────────────────────────
      {
        id: "meta-rotation",
        schedule: "30 */3 * * *",         // Every 3 hours at :30
        agentId: "onchain-analyst",
        message: "CRON_JOB: meta_rotation_analysis — Analyze narrative clusters across recent scans and trades. Identify hot vs cooling metas. Write observations to memory.",
        enabled: true
      },

      // ── V2 Specialist Agents ──────────────────────────────────────
      {
        id: "whale-watch",
        schedule: "0 */2 * * *",          // Every 2 hours
        agentId: "smart-money-tracker",
        message: "CRON_JOB: whale_activity_scan — Scan for large wallet movements, deployer activity, accumulation patterns. Detect smart money consensus and fresh wallet surges.",
        enabled: true
      },
      {
        id: "sentiment-trend",
        schedule: "0 */4 * * *",          // Every 4 hours
        agentId: "social-analyst",
        message: "CRON_JOB: sentiment_trend_analysis — Analyze Twitter/X trending tokens, influencer clustering, mention velocity, narrative exhaustion signals. Write to memory.",
        enabled: true
      },

      // ── Portfolio Maintenance (CTO) ───────────────────────────────
      {
        id: "dead-money-sweep",
        schedule: "0 */2 * * *",          // Every 2 hours
        agentId: "cto",
        message: "CRON_JOB: dead_money_sweep — Check all open LOCAL_MANAGED positions for dead money. Exit stale positions. Tag as dead_money.",
        enabled: true
      },
      {
        id: "subscription-cleanup",
        schedule: "0 * * * *",            // Every hour
        agentId: "cto",
        message: "CRON_JOB: subscription_cleanup — Check active Bitquery subscriptions. Unsubscribe from streams no longer needed (sold tokens, closed positions).",
        enabled: true
      },

      // ── Reporting ─────────────────────────────────────────────────
      {
        id: "daily-report",
        schedule: "0 4 * * *",            // Daily at 04:00 UTC
        agentId: "cto",
        message: "CRON_JOB: daily_performance_report — Calculate daily PnL, aggregate win/loss stats, source reputation summary, write comprehensive memory entry.",
        enabled: true
      },

      // ── V2 Execution Health ───────────────────────────────────────
      {
        id: "execution-health",
        schedule: "0 */6 * * *",          // Every 6 hours
        agentId: "execution-specialist",
        message: "CRON_JOB: execution_health_review — Review recent trade executions for slippage patterns, timing efficiency, failed transactions. Report execution quality metrics.",
        enabled: true
      },

      // ── Alpha Scanning ──────────────────────────────────────────────
      {
        id: "alpha-scan",
        schedule: "0 * * * *",            // Every hour
        agentId: "alpha-signal-analyst",
        message: "CRON_JOB: alpha_scan — Call solana_scan_launches to find new token launches from the last hour. For each candidate, call solana_token_snapshot to check price, volume, and age. Filter for: 24h volume above 50000 USD, market cap above 10000 USD. For tokens that pass, call solana_token_holders to check holder distribution (skip if top holder owns more than 30 percent), then solana_token_risk to check for mint/freeze authority (hard skip if present). If a token passes all checks, call solana_alpha_submit to add it to the alpha buffer for the CTO's next heartbeat evaluation. Log all scanned tokens and results using solana_memory_write. Do not execute trades directly — only submit to alpha buffer. Do not ask questions.",
        enabled: true
      }
    ]
  },

  hooks: {
    enabled: true,
    token: "REPLACE_WITH_SECURE_TOKEN",
    mappings: [
      {
        // High-priority alpha signals from SpyFly aggregator
        // Triggers immediate agent turn outside heartbeat cadence
        match: { path: "alpha-signal" },
        action: "agent",
        agentId: "main",
        deliver: true
      },
      {
        // Bitquery firehose alerts for on-chain discovery events
        // Wakes agent for immediate analysis
        match: { path: "firehose-alert" },
        action: "agent",
        agentId: "main",
        deliver: true
      }
    ]
  }
}
